{
  "name": "sajda",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:landing": "turbo dev --filter=landing",
    "dev:jemaah": "turbo dev --filter=jemaah",
    "dev:admin": "turbo dev --filter=admin",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}